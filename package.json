{
  "name": "studycommander",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "vite-node scripts/smoke.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "icons": "node scripts/generate-icons.mjs",
    "typecheck:functions": "tsc -p tsconfig.functions.json",
    "pages:dev": "npm run build && wrangler pages dev dist --d1=DB",
    "d1:schema": "wrangler d1 execute studycommander-db --remote --file=./schema/schema.sql",
    "d1:schema:local": "wrangler d1 execute studycommander-db --local --file=./schema/schema.sql"
  },
  "dependencies": {
    "@fontsource-variable/noto-sans-jp": "^5.2.10",
    "lucide-react": "^1.23.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260708.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "playwright": "^1.61.1",
    "sharp": "^0.33.5",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-node": "^2.1.9",
    "vite-plugin-pwa": "^0.20.5",
    "wrangler": "^4.108.0"
  }
}
